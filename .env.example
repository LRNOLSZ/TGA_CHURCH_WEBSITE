# Django Settings
DEBUG=False
SECRET_KEY=your-super-secret-key-here-generate-a-secure-one

# Database — copy values from Railway PostgreSQL service Variables panel
DB_NAME=railway
DB_USER=postgres
DB_PASSWORD=your-railway-db-password
DB_HOST=your-db-host.railway.internal
DB_PORT=5432

# Allowed Hosts — your Railway backend URL (no https://)
ALLOWED_HOSTS=your-app-name.up.railway.app

# CORS — your Vercel frontend URL
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# Cloudflare R2 — for media/image uploads
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
CLOUDFLARE_R2_BUCKET_NAME=tga-church-media
CLOUDFLARE_R2_PUBLIC_URL=pub-51a61b12d8524bc28bfe6d2ec895f82f.r2.dev
